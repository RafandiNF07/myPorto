---
import { siteConfig } from "../config/site";

const socials = [
  { name: "GitHub", url: siteConfig.socials.github },
  { name: "LinkedIn", url: siteConfig.socials.linkedin },
  { name: "Email", url: `mailto:${siteConfig.email}` },
];
---

<section
  id="contact"
  class="md:col-span-12 minimal-card border border-white/[0.08] rounded-3xl p-8 md:p-12 relative overflow-hidden text-center scroll-mt-32 motion-fade opacity-0"
>
  <div class="relative z-10 max-w-xl mx-auto flex flex-col items-center">
    <h2
      class="font-display font-semibold text-3xl md:text-5xl text-white mb-6 tracking-tight"
    >
      Let's build.
    </h2>
    <p
      class="text-text-sec text-base md:text-lg leading-relaxed mb-10 font-sans"
    >
      I'm open to discussing infrastructure architecture, backend challenges, or
      collaboration opportunities.
    </p>

    <div class="flex flex-wrap justify-center gap-3 w-full mb-12">
      {
        socials.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group active-press px-6 py-3 bg-transparent border border-white/10 font-sans text-sm tracking-wide rounded-full hover:border-white/30 hover:bg-white/5 hover:-translate-y-0.5 transition-all duration-300"
          >
            <span class="text-text-sec group-hover:text-white transition-colors">
              {social.name}
            </span>
          </a>
        ))
      }
    </div>

    <div class="flex justify-center w-full">
      <div
        class="text-[10px] font-sans text-text-muted flex items-center gap-2 uppercase tracking-widest"
      >
        <span class="w-1.5 h-1.5 bg-white/40 rounded-full"></span>
        Available for opportunities
      </div>
    </div>
  </div>
</section>
