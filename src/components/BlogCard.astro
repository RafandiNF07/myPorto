---
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
---

<a href={`/blog/${post.id}/`} class="motion-slide group block minimal-card rounded-3xl p-8 md:p-12 relative overflow-hidden opacity-0 border border-white/[0.06] hover:border-white/[0.15] hover:-translate-y-1 hover:shadow-2xl transition-all duration-500">
  
  <div class="relative z-10 flex flex-col md:flex-row md:items-start justify-between gap-8">
    <div class="flex-1">
      <div class="flex items-center gap-4 mb-6">
          <span class="tag-minimal">
            {post.data.tags[0] || 'ARTICLE'}
          </span>
          <div class="text-xs font-mono text-text-sec flex items-center gap-2 px-2 py-1 rounded">
            <span class="w-1.5 h-1.5 rounded-full bg-white/40 group-hover:bg-white transition-colors duration-300" />
            <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-us', {
                  year: 'numeric',
                  month: 'long',
                })}
            </time>
          </div>
      </div>
      <h3 class="font-display font-semibold text-2xl md:text-3xl text-white mb-4 tracking-tight group-hover:text-sage transition-colors duration-300">
        {post.data.title}
      </h3>
      <p class="text-text-sec text-sm md:text-base leading-relaxed mb-6 font-sans max-w-2xl">
        {post.data.description}
      </p>
    </div>
    
    <div class="hidden md:flex items-center text-text-muted text-xs font-sans uppercase tracking-wider group-hover:text-white transition-colors pt-4">
      Read <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
    </div>
  </div>
  <div class="md:hidden flex justify-start relative z-10 pt-6 border-t border-white/5">
    <span class="text-text-muted font-sans text-xs uppercase tracking-wider group-hover:text-white transition-colors duration-300 flex items-center gap-2">
      Read Article <span class="text-[10px] group-hover:translate-x-1 transition-transform">→</span>
    </span>
  </div>
</a>
