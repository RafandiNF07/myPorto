---
import { siteConfig } from "../config/site";
import { footerLinks } from "../data/nav";
---

<footer
  class="max-w-6xl mx-auto px-4 md:px-8 pb-6 pt-8 mt-6 md:mt-16 border-t border-white/4"
>
  <div
    class="flex flex-col md:flex-row justify-between items-start gap-6 md:gap-8 mb-6"
  >
    <div class="flex flex-col max-w-sm">
      <h3
        class="font-display font-medium text-xl md:text-2xl text-white mb-2 tracking-tight"
      >
        {siteConfig.name}
      </h3>
      <p
        class="font-sans text-sm text-text-sec leading-[1.7] mb-4 hidden sm:block"
      >
        {siteConfig.description}
      </p>

      <div
        class="hidden sm:inline-flex items-center gap-3 px-4 py-2 rounded-full border border-white/5 bg-white/2 w-fit"
      >
        <span
          class="font-mono text-[10px] uppercase tracking-widest text-text-muted"
          >Available for opportunities</span
        >
      </div>
    </div>

    <div class="grid grid-cols-2 gap-6 md:gap-16">
      <div class="flex flex-col gap-2">
        <span
          class="font-sans text-xs uppercase tracking-widest text-text-muted mb-1 md:mb-2"
          >Connect</span
        >
        <a
          href={siteConfig.socials.github}
          target="_blank"
          rel="noopener noreferrer"
          class="font-sans text-sm text-text-sec hover:text-white transition-colors py-1.5 md:py-1.5 block"
          >GitHub</a
        >
        <a
          href={siteConfig.socials.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="font-sans text-sm text-text-sec hover:text-white transition-colors py-1.5 md:py-1.5 block"
          >LinkedIn</a
        >
        <a
          href={`mailto:${siteConfig.email}`}
          class="font-sans text-sm text-text-sec hover:text-white transition-colors py-1.5 md:py-1.5 block"
          >Email</a
        >
      </div>

      <div class="flex flex-col gap-2">
        <span
          class="font-sans text-xs uppercase tracking-widest text-text-muted mb-1 md:mb-2"
          >Index</span
        >
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class="font-sans text-sm text-text-sec hover:text-white transition-colors py-1.5 md:py-1.5 block"
            >
              {link.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="flex flex-col md:flex-row justify-between items-center gap-2 pt-5 border-t border-white/4"
  >
    <p class="font-sans text-xs text-text-muted">
      &copy; {new Date().getFullYear()}
      {siteConfig.name}.
    </p>
    <div
      class="hidden sm:flex font-mono text-[10px] uppercase tracking-widest text-text-muted items-center gap-4"
    >
      <span>Built with Astro</span>
      <span class="w-1 h-1 rounded-full bg-white/20"></span>
      <span>Styled with Tailwind V4</span>
    </div>
  </div>
</footer>
