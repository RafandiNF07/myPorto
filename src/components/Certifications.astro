---
import { certifications } from "../data/certifications";
---

<section id="certifications" class="md:col-span-12 scroll-mt-32 relative z-10">
  <div class="mb-10">
      <h2 class="font-display font-medium text-xl md:text-2xl text-white tracking-tight flex items-center gap-3">
        <span class="w-2 h-2 rounded-full bg-white/40"></span>
        Verified Credentials
      </h2>
  </div>

  <div class="minimal-card rounded-2xl border border-white/[0.04] p-6 md:p-8">
    <div class="hidden md:grid grid-cols-12 gap-4 text-xs font-sans text-text-muted uppercase tracking-wider border-b border-white/5 pb-4 mb-4">
      <div class="col-span-1">Status</div>
      <div class="col-span-4">Credential</div>
      <div class="col-span-3">Issuer</div>
      <div class="col-span-2">Date</div>
      <div class="col-span-2 text-right">Action</div>
    </div>
    
    <ul class="flex flex-col">
      {
        certifications.map((cert, idx) => (
          <li class={`group ${idx !== certifications.length - 1 ? 'border-b border-white/5' : ''}`}>
            <a href={cert.link} target="_blank" rel="noopener noreferrer" class="grid grid-cols-1 md:grid-cols-12 gap-4 items-center py-4 md:py-6 hover:bg-white/[0.02] transition-colors rounded-lg px-2 -mx-2">
                <div class="hidden md:block col-span-1">
                  <div class="w-5 h-5 rounded-full bg-white/10 flex items-center justify-center group-hover:bg-sage/20 group-hover:text-sage transition-colors">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                </div>
                
                <div class="md:col-span-4 flex flex-col">
                  <span class="font-medium text-white text-base group-hover:text-sage transition-colors">{cert.name}</span>
                  <span class="text-xs text-text-muted font-sans font-mono md:hidden mt-1">{cert.recordId}</span>
                </div>
                
                <div class="md:col-span-3 text-sm text-text-sec font-sans">
                  {cert.issuer}
                </div>
                
                <div class="hidden md:block col-span-2 text-sm text-text-sec font-sans">
                  {cert.date}
                </div>
                
                <div class="md:col-span-2 text-left md:text-right">
                  {cert.status === 'lost' ? (
                     <span class="text-xs font-sans text-text-muted uppercase tracking-wider flex items-center md:justify-end gap-1 opacity-50">
                       Unavailable
                     </span>
                  ) : (
                    <span class="text-xs font-sans text-text-muted uppercase tracking-wider group-hover:text-white transition-colors flex items-center md:justify-end gap-1">
                      Verify <span class="group-hover:translate-x-1 transition-transform">↗</span>
                    </span>
                  )}
                </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
