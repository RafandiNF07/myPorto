---
import { siteConfig } from "../config/site";
---

<div id="top" class="section-anim md:col-span-12 minimal-card border border-white/[0.03] rounded-3xl p-8 md:p-12 lg:p-16 relative overflow-hidden flex flex-col md:flex-row items-center justify-between min-h-[75vh] lg:min-h-[80vh] group/system">
  
  <div class="relative z-10 w-full max-w-4xl mx-auto text-center md:text-left flex flex-col items-center md:items-start">
    <div class="inline-flex items-center gap-3 mb-8 motion-fade">
      <span class="w-2 h-2 rounded-full bg-white opacity-40"></span>
      <span class="font-sans text-[11px] tracking-[0.2em] text-text-sec uppercase">Backend Engineer</span>
    </div>
    
    <h1 class="font-display font-semibold text-5xl md:text-7xl lg:text-8xl leading-[1.05] tracking-tighter text-white mb-8 motion-fade" style="transition-delay: 100ms;">
      <span class="block text-text-muted text-3xl md:text-5xl font-medium tracking-tight mb-4">Rafandi Nova Fitra.</span>
      Building <span class="text-white">resilient</span> systems.
    </h1>
    
    <p class="text-text-sec font-sans text-base md:text-lg max-w-2xl leading-relaxed mb-12 motion-fade" style="transition-delay: 200ms;">
      I design and develop high-performance backend architectures, focusing on scalability, robust linux internals, and distributed systems that power modern applications.
    </p>

    <div class="flex flex-col sm:flex-row items-center gap-4 motion-fade" style="transition-delay: 300ms;">
      <a href="/#work" class="px-8 py-4 bg-white text-black font-sans font-medium text-sm tracking-wide rounded-full hover:bg-opacity-90 hover:scale-105 transition-all duration-300">
        View Projects
      </a>
      <a href={`mailto:${siteConfig.email}`} class="px-8 py-4 bg-transparent border border-white/20 text-white font-sans font-medium text-sm tracking-wide rounded-full hover:bg-white/5 hover:border-white/40 transition-all duration-300">
        Get in Touch
      </a>
    </div>
  </div>

  <!-- Very subtle background element -->
  <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-white opacity-[0.02] rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
</div>
