---
import { siteConfig } from "../config/site";
---

<div
  id="top"
  class="section-anim md:col-span-12 minimal-card border border-white/3 rounded-3xl p-6 md:p-10 lg:p-12 relative overflow-hidden flex flex-col md:flex-row items-stretch justify-between min-h-[88dvh] group/system"
>
  <div
    class="relative z-10 w-full grid grid-cols-1 md:grid-cols-[minmax(0,1.2fr)_minmax(280px,0.8fr)] gap-12 items-center"
  >
    <div
      class="w-full max-w-3xl mx-auto text-center md:text-left flex flex-col items-center md:items-start"
    >
      <div
        class="inline-flex items-center gap-3 mb-6 motion-fade rounded-full border border-white/8 bg-white/2 px-4 py-2"
      >
        <span class="w-2 h-2 rounded-full bg-sage"></span>
        <span
          class="font-sans text-[11px] tracking-[0.18em] text-text-sec uppercase"
          >Backend systems · Linux · Security</span
        >
      </div>

      <h1
        class="font-display font-semibold text-4xl md:text-6xl lg:text-7xl leading-[1.03] tracking-tighter text-white mb-6 motion-fade"
        style="transition-delay: 100ms;"
      >
        <span
          class="block text-text-muted text-2xl md:text-4xl font-medium tracking-tight mb-3"
          >Rafandi Nova Fitra</span
        >
        Backend & Cybersecurity Enthusiast
      </h1>

      <p
        class="text-text-sec font-sans md:text-lg max-w-xl leading-relaxed mb-10 motion-fade"
        style="transition-delay: 200ms;"
      >
        Informatics student focused on backend engineering, Linux,
        cybersecurity, and fullstack web development. I like turning technical
        curiosity into systems that are clear, durable, and useful.
      </p>

      <div
        class="flex flex-col sm:flex-row items-center gap-4 motion-fade"
        style="transition-delay: 300ms;"
      >
        <a
          href="/#work"
          class="active-press px-8 py-4 bg-white text-black font-sans font-medium text-sm tracking-wide rounded-full hover:bg-opacity-90 hover:scale-[1.02] transition-all duration-300"
        >
          View Projects
        </a>
        <a
          href={`mailto:${siteConfig.email}`}
          class="active-press px-8 py-4 bg-transparent border border-white/20 text-white font-sans font-medium text-sm tracking-wide rounded-full hover:bg-white/5 hover:border-white/40 transition-all duration-300"
        >
          Get in Touch
        </a>
      </div>
    </div>

    <div
      class="relative w-full max-w-[24rem] mx-auto md:mx-0 md:justify-self-end motion-fade"
      style="transition-delay: 220ms;"
    >
      <div class="absolute inset-0 rounded-4xl bg-white/2 blur-3xl opacity-40">
      </div>
      <div
        class="minimal-card rounded-4xl border border-white/6 bg-white/1.5 p-5 md:p-6 relative overflow-hidden"
      >
        <div class="absolute inset-0 opacity-20">
          <svg
            class="h-full w-full"
            viewBox="0 0 400 560"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M48 32H352M48 96H352M48 160H352M48 224H352M48 288H352M48 352H352M48 416H352M48 480H352"
              stroke="white"
              stroke-opacity="0.08"
              stroke-width="1"></path>
            <path
              d="M56 40V520M200 40V520M344 40V520"
              stroke="white"
              stroke-opacity="0.06"
              stroke-width="1"></path>
            <circle cx="88" cy="132" r="3" fill="white" fill-opacity="0.35"
            ></circle>
            <circle cx="312" cy="196" r="3" fill="white" fill-opacity="0.35"
            ></circle>
            <circle cx="248" cy="372" r="3" fill="white" fill-opacity="0.35"
            ></circle>
            <circle cx="144" cy="456" r="3" fill="white" fill-opacity="0.35"
            ></circle>
          </svg>
        </div>

        <div class="relative z-10 flex h-full flex-col gap-6">
          <div
            class="flex items-center justify-between border-b border-white/5 pb-4"
          >
            <div>
              <p
                class="text-[11px] uppercase tracking-[0.18em] text-text-muted"
              >
                Engineering Evidence
              </p>
              <p class="mt-1.5 font-display text-lg text-white tracking-tight">
                System-first mindset
              </p>
            </div>
            <div class="text-right text-xs font-mono text-text-sec">
              <p>Portfolio</p>
              <p>2026</p>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-2xl border border-white/6 bg-black/20 p-3.5">
              <p
                class="text-[10px] uppercase tracking-[0.18em] text-text-muted"
              >
                Focus
              </p>
              <p class="mt-3 text-sm text-white leading-relaxed">
                Backend systems, Linux, security
              </p>
            </div>
            <div class="rounded-2xl border border-white/6 bg-black/20 p-3.5">
              <p
                class="text-[10px] uppercase tracking-[0.18em] text-text-muted"
              >
                Builds
              </p>
              <p class="mt-3 text-sm text-white leading-relaxed">
                Backend APIs, Linux servers, and web applications
              </p>
            </div>
          </div>

          <div class="rounded-2xl border border-white/6 bg-black/25 p-3.5">
            <p
              class="text-[10px] uppercase tracking-[0.18em] text-text-muted mb-3"
            >
              Current stack
            </p>
            <div class="space-y-3 text-sm text-text-sec">
              <div class="flex items-center justify-between gap-4">
                <span>FastAPI / Node.js</span><span class="text-white"
                  >Backend</span
                >
              </div>
              <div class="flex items-center justify-between gap-4">
                <span>PostgreSQL / Redis</span><span class="text-white"
                  >Data</span
                >
              </div>
              <div class="flex items-center justify-between gap-4">
                <span>Linux / Docker</span><span class="text-white">Ops</span>
              </div>
              <div class="flex items-center justify-between gap-4">
                <span>NextJS / SvelteKit</span><span class="text-white"
                  >Full Web Dev</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
