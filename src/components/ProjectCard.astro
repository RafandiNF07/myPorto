---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  index: number;
}

const { project, index } = Astro.props;

// Determine if we have a valid githubLink
const hasGithub = !!project.data.githubLink && project.data.githubLink !== "#";
const hasLive = !!project.data.liveLink && project.data.liveLink !== "#";

// Class generation based on index to retain the editorial layout
const cardClass = `motion-slide group block ${index % 2 === 0 ? "md:col-span-7" : "md:col-span-5"} minimal-card rounded-3xl p-8 md:p-12 relative overflow-hidden opacity-0 border border-white/[0.06] hover:border-white/[0.15] hover:-translate-y-1 hover:shadow-2xl transition-all duration-500 ${index === 0 ? "scroll-mt-24" : ""}`;
---

<div class={cardClass}>
  <a
    href={`/projects/${project.id}/`}
    class="absolute inset-0 z-0"
    aria-label={`Read case study for ${project.data.title}`}></a>

  <div class="relative z-10 flex flex-col h-full pointer-events-none">
    <div class="flex flex-col flex-1">
      <div class="flex justify-between items-start mb-6">
        <span class="tag-minimal">
          PROJECT{" "}
          {project.id.split(".").shift()?.toUpperCase() || `0${index + 1}`}
        </span>
        <div
          class="text-xs font-mono text-text-sec flex items-center gap-2 px-2 py-1 rounded"
        >
          <span
            class="w-1.5 h-1.5 rounded-full bg-white/40 group-hover:bg-white transition-colors duration-300"
          ></span>
          {project.data.pubDate.getFullYear()}
        </div>
      </div>

      <h3
        class="font-display font-semibold text-2xl md:text-3xl text-white mb-4 tracking-tight group-hover:text-sage transition-colors duration-300 pointer-events-auto w-fit"
      >
        <a href={`/projects/${project.id}/`}>{project.data.title}</a>
      </h3>

      <div class="space-y-4 mb-8 flex-1">
        <div>
          <h4
            class="text-xs font-sans text-text-muted uppercase tracking-wider mb-1"
          >
            Architecture / Challenge
          </h4>
          <p class="text-text-sec leading-relaxed font-sans text-sm">
            {project.data.description}
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 border-t border-white/5 pt-4 mb-4">
        <div class="text-xs font-sans text-text-muted uppercase tracking-wider">
          <span class="block text-white/30 mb-1">Role</span>
          <span class="text-text-main">Backend</span>
        </div>
        <div class="text-xs font-sans text-text-muted uppercase tracking-wider">
          <span class="block text-white/30 mb-1">Context</span>
          <span class="text-text-main">Production</span>
        </div>
      </div>
    </div>

    <div
      class="mt-auto flex flex-wrap items-center justify-between gap-4 border-t border-white/5 pt-6 pointer-events-auto"
    >
      <div class="flex flex-wrap gap-2">
        {project.data.tags.map((tag) => <span class="tag-minimal">{tag}</span>)}
      </div>
      <div class="flex items-center gap-4">
        {
          hasGithub ? (
            <a
              href={project.data.githubLink}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-sec text-sm font-sans hover:text-white transition-colors flex items-center gap-2 group/link"
            >
              Source
              <span class="text-xs group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform">
                ↗
              </span>
            </a>
          ) : (
            <span class="text-text-sec text-sm font-sans flex items-center gap-2 opacity-50">
              Private Repo
            </span>
          )
        }
        {
          hasLive && (
            <a
              href={project.data.liveLink}
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-sec text-sm font-sans hover:text-white transition-colors flex items-center gap-2 group/link"
            >
              Live Demo
              <span class="text-xs group-hover/link:translate-x-1 group-hover/link:-translate-y-1 transition-transform">
                ↗
              </span>
            </a>
          )
        }
      </div>
    </div>
  </div>
</div>
