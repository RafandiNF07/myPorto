---
import { capabilities, currentlyLearning } from "../data/skills";
---

<section
  id="skills"
  class="md:col-span-12 minimal-card border border-white/4 rounded-3xl p-8 md:p-12 relative overflow-hidden scroll-mt-32 motion-fade opacity-0"
>
  <div class="relative z-10">
    <div class="mb-12 text-center">
      <h2
        class="font-display font-semibold text-3xl md:text-5xl text-white tracking-tight"
      >
        Technical Stack.
      </h2>
    </div>

    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 md:gap-8 pt-8 border-t border-white/5"
    >
      {
        capabilities.map((cap) => (
          <div class="flex flex-col relative group">
            <h3 class="font-sans text-text-sec text-sm uppercase tracking-widest mb-6 border-b border-white/5 pb-4">
              {cap.domain}
            </h3>

            <div class="space-y-4">
              {cap.skills.map((skill) => (
                <div class="flex items-center gap-3 font-sans text-sm">
                  <span class="w-1.5 h-1.5 rounded-full bg-white/20 group-hover:bg-sage transition-colors duration-300" />
                  <span class="text-text-main">{skill}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-12 border-t border-white/5 pt-8 motion-fade">
      <h3
        class="font-sans text-text-sec text-sm uppercase tracking-widest mb-6 flex items-center gap-3"
      >
        <span class="w-2 h-2 rounded-full bg-sage/40 animate-pulse"></span>
        Currently Learning
      </h3>
      <div class="flex flex-wrap gap-3">
        {
          currentlyLearning.map((item) => (
            <span class="px-4 py-2 rounded-full text-xs font-sans text-text-muted bg-white/2 border border-white/5">
              {item}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
