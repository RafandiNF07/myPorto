---
import "@fontsource-variable/geist/index.css";
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";
import MotionObserver from "../components/MotionObserver.astro";
interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = "Backend Developer & IT Student";
const siteDescription = "Rafandi Nova Fitra - Backend Developer & IT Student";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <SEOHead
      title={`${title} | ${siteTitle}`}
      description={description ?? siteDescription}
    />
  </head>
  <body
    class="bg-base text-text-main min-h-screen font-sans selection:bg-sage/30 relative"
  >
    <!-- SCANLINE OVERLAY -->
    <div class="scanline-overlay"></div>
    <div class="noise-overlay"></div>

    <!-- SYSTEM NERVE (Global Background Connection) -->
    <div class="fixed inset-0 pointer-events-none z-0 opacity-[0.03]">
      <svg
        class="w-full h-full text-white"
        viewBox="0 0 100 100"
        preserveAspectRatio="none"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
      >
        <!-- Vertical lines -->
        <path
          d="M15 0 L15 100 M85 0 L85 100"
          stroke="currentColor"
          stroke-width="0.5"></path>

        <!-- Main connection -->
        <path
          d="M50 0 L50 15 L65 30 L65 70 L50 85 L50 100"
          stroke="currentColor"
          stroke-width="0.5"></path>

        <!-- Dashed line -->
        <path
          d="M35 20 L35 80"
          stroke="currentColor"
          stroke-width="0.5"
          stroke-dasharray="2 2"></path>

        <!-- Side connections -->
        <path
          d="M15 20 L35 20 M65 30 L85 30 M35 70 L65 70"
          stroke="currentColor"
          stroke-width="0.5"
          opacity="0.5"></path>

        <!-- Nodes -->
        <circle cx="15" cy="20" r="0.8" fill="currentColor"></circle>
        <circle cx="85" cy="40" r="0.8" fill="currentColor"></circle>
        <circle cx="50" cy="15" r="1" fill="currentColor"></circle>
        <circle cx="65" cy="30" r="1" fill="currentColor"></circle>
        <circle cx="65" cy="70" r="1" fill="currentColor"></circle>
        <circle cx="50" cy="85" r="1" fill="currentColor"></circle>
        <circle cx="35" cy="50" r="0.8" fill="currentColor"></circle>
      </svg>
    </div>

    <Navbar />
    <slot />
    <Footer />
    <MotionObserver />
  </body>
</html>
